# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/

# Pipenv (nunca subir el venv; sí Pipfile.lock)
Pipfile.lock.bak

# Node
node_modules/
dist/
.vite/

# Entornos y secretos
.env
.env.*
!.env.example

# Docker
*.pid
# Override de puertos locales: si se comitea, cualquier `docker compose up`
# en un servidor real también lo tomaría y expondría los puertos directo
# a internet, saltándose el Caddy/reverse proxy de producción.
docker-compose.override.yml

# Editor / OS
.DS_Store
.vscode/
.idea/

# Alembic (se versionan las migraciones, no artefactos temporales)
*.sqlite3

# Sphinx (se versiona docs/source, el HTML se regenera con sphinx-build)
backend/docs/build/
